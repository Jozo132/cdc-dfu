{
    "name": "cdc-dfu",
    "version": "1.1.0",
    "description": "Zero-overhead DFU bootloader jump for STM32 (F4, H7) via USB CDC DTR toggling. Auto-configures DFU upload trigger for PlatformIO.",
    "keywords": "stm32, stm32f4, stm32h7, dfu, bootloader, usb, cdc, upload",
    "repository": {
        "type": "git",
        "url": "https://github.com/Jozo132/cdc-dfu.git"
    },
    "authors": [
        {
            "name": "Jozo132"
        }
    ],
    "license": "MIT",
    "frameworks": "arduino",
    "platforms": "ststm32",
    "build": {
        "flags": "-D DTR_TOGGLING_SEQ",
        "extraScript": "extra_script.py",
        "libArchive": false,
        "srcFilter": "-<*>"
    },
    "export": {
        "include": [
            "src/*",
            "examples/*",
            "extra_script.py",
            "library.json",
            "README.md",
            "LICENSE"
        ]
    }
}
