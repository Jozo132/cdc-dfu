{
    "name": "cdc-dfu",
    "version": "1.1.0",
    "private": true,
    "description": "Zero-overhead DFU bootloader jump for STM32 via USB CDC",
    "scripts": {
        "example:blinky-f401cc": "pio run -d examples/blinky-f401cc",
        "example:blinky-f401cc:upload": "pio run -d examples/blinky-f401cc --target upload",
        "example:blinky-f401cc:monitor": "pio device monitor -d examples/blinky-f401cc",
        "example:blinky-h743vi": "pio run -d examples/blinky-h743vi",
        "example:blinky-h743vi:upload": "pio run -d examples/blinky-h743vi --target upload",
        "example:blinky-h743vi:monitor": "pio device monitor -d examples/blinky-h743vi",
        "test:blinky-f401cc": "pio run -d test/blinky-f401cc --target upload",
        "test:blinky-h743vi": "pio run -d test/blinky-h743vi --target upload"
    }
}
